# Copy to .env and fill in (never commit .env)

# Gmail address that sends mail (must match the account for the app password)
GMAIL_USER=cognitionapex@gmail.com

# Gmail App Password (Google Account → Security → 2-Step Verification → App passwords)
GMAIL_APP_PASSWORD=your_16_character_app_password

# Where contact form submissions are delivered (usually same as GMAIL_USER)
CONTACT_TO=cognitionapex@gmail.com

# Optional: API port for local Express only (default 8787)
# CONTACT_API_PORT=8787

# Vercel: add the same three vars (GMAIL_USER, GMAIL_APP_PASSWORD, CONTACT_TO) in
# Project → Settings → Environment Variables (Production + Preview if needed).
